{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://logihub-intelligence.local/schemas/engine_contract_v1_0.schema.json",
  "title": "LogiHubEngineContract",
  "description": "Full JSON Contract Schema for the LogiHub Logistics Engine. This schema represents the complete engine output payload used by backend modules, outcome renderer, report generator, and Decision Cockpit frontend.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "run_info",
    "proxy_scope",
    "input_data_summary",
    "data_quality_report",
    "master_data",
    "demand",
    "product_segmentation",
    "baseline_network",
    "cost_model",
    "capacity_model",
    "diagnosis",
    "optimization_models",
    "scenarios",
    "recommended_network",
    "allocation",
    "seasonal_playbook",
    "business_case",
    "roadmap",
    "outcome_report",
    "artifacts",
    "warnings",
    "errors"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "description": "Locked schema contract version.",
      "pattern": "^v[0-9]+\\.[0-9]+(-locked)?$",
      "examples": [
        "v1.0-locked"
      ]
    },
    "run_info": {
      "$ref": "#/definitions/runInfo"
    },
    "proxy_scope": {
      "$ref": "#/definitions/proxyScope"
    },
    "input_data_summary": {
      "$ref": "#/definitions/inputDataSummary"
    },
    "data_quality_report": {
      "$ref": "#/definitions/dataQualityReport"
    },
    "master_data": {
      "$ref": "#/definitions/masterData"
    },
    "demand": {
      "$ref": "#/definitions/demand"
    },
    "product_segmentation": {
      "$ref": "#/definitions/productSegmentation"
    },
    "baseline_network": {
      "$ref": "#/definitions/baselineNetwork"
    },
    "cost_model": {
      "$ref": "#/definitions/costModel"
    },
    "capacity_model": {
      "$ref": "#/definitions/capacityModel"
    },
    "diagnosis": {
      "$ref": "#/definitions/diagnosis"
    },
    "optimization_models": {
      "$ref": "#/definitions/optimizationModels"
    },
    "scenarios": {
      "type": "array",
      "description": "Scenario-level outputs S0-S8. This is the primary block consumed by the frontend scenario comparison view.",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/scenario"
      }
    },
    "recommended_network": {
      "$ref": "#/definitions/recommendedNetwork"
    },
    "allocation": {
      "type": "array",
      "description": "Detailed region/product-to-hub allocation records for the recommended scenario unless scenario_id is otherwise specified.",
      "items": {
        "$ref": "#/definitions/allocationRecord"
      }
    },
    "seasonal_playbook": {
      "type": "array",
      "description": "Operational playbook for predictable demand spikes, product launches, and seasonal capacity actions.",
      "items": {
        "$ref": "#/definitions/seasonalEvent"
      }
    },
    "business_case": {
      "$ref": "#/definitions/businessCase"
    },
    "roadmap": {
      "type": "array",
      "description": "Implementation roadmap divided into phases.",
      "items": {
        "$ref": "#/definitions/roadmapPhase"
      }
    },
    "outcome_report": {
      "$ref": "#/definitions/outcomeReport"
    },
    "artifacts": {
      "type": "array",
      "description": "Generated artifacts and intermediate output files.",
      "items": {
        "$ref": "#/definitions/artifact"
      }
    },
    "warnings": {
      "type": "array",
      "description": "Non-fatal warnings, assumptions, and limitations that should be surfaced in report and frontend.",
      "items": {
        "$ref": "#/definitions/warning"
      }
    },
    "errors": {
      "type": "array",
      "description": "Fatal or module-level errors. Empty array means no fatal errors.",
      "items": {
        "$ref": "#/definitions/error"
      }
    }
  },
  "definitions": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "ratio": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "percentage": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "nonNegativeNumber": {
      "type": "number",
      "minimum": 0
    },
    "nonNegativeInteger": {
      "type": "integer",
      "minimum": 0
    },
    "currency": {
      "type": "string",
      "enum": [
        "USD",
        "KRW",
        "VND",
        "EUR",
        "JPY"
      ]
    },
    "unit": {
      "type": "string",
      "enum": [
        "ton",
        "kg",
        "pallet",
        "unit",
        "shipment",
        "carton",
        "cbm",
        "index"
      ]
    },
    "regionName": {
      "type": "string",
      "enum": [
        "Seoul",
        "Busan",
        "Daegu",
        "Incheon",
        "Gwangju",
        "Daejeon",
        "Ulsan",
        "Sejong",
        "Gyeonggi",
        "Gangwon",
        "Chungbuk",
        "Chungnam",
        "Jeonbuk",
        "Jeonnam",
        "Gyeongbuk",
        "Gyeongnam",
        "Jeju",
        "Unknown"
      ]
    },
    "productFamily": {
      "type": "string",
      "enum": [
        "Fresh_Food",
        "FMCG_Packaged",
        "Industrial_Materials",
        "Durables_Electronics",
        "Ecommerce_Misc"
      ]
    },
    "riskLevel": {
      "type": "string",
      "enum": [
        "Low",
        "Medium",
        "High",
        "Critical"
      ]
    },
    "hubStatus": {
      "type": "string",
      "enum": [
        "underused",
        "healthy",
        "watchlist",
        "seasonal_watch",
        "overload",
        "critical",
        "crisis"
      ]
    },
    "hubRole": {
      "type": "string",
      "enum": [
        "metro_fulfillment",
        "secure_node",
        "central_balancing",
        "launch_hub",
        "bulky_appliance",
        "southern_port",
        "regional_hub",
        "service_node",
        "crossdock",
        "overflow"
      ]
    },
    "scenarioId": {
      "type": "string",
      "pattern": "^S[0-8]$"
    },
    "runInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_run_id",
        "engine_version",
        "run_mode",
        "created_at",
        "execution_time_ms",
        "status"
      ],
      "properties": {
        "scenario_run_id": {
          "type": "string",
          "description": "Unique ID for this engine execution run.",
          "pattern": "^run_[A-Za-z0-9_.:-]+$"
        },
        "run_uuid": {
          "type": "string",
          "format": "uuid"
        },
        "engine_version": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "run_mode": {
          "type": "string",
          "enum": [
            "mock",
            "proxy",
            "production"
          ]
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "created_by": {
          "type": "string"
        },
        "execution_time_ms": {
          "$ref": "#/definitions/nonNegativeNumber"
        },
        "status": {
          "type": "string",
          "enum": [
            "success",
            "partial_success",
            "failed"
          ]
        }
      }
    },
    "proxyScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "is_proxy",
        "data_source_type",
        "data_sources",
        "geographic_scope",
        "analysis_period",
        "target_company_context",
        "disclaimer"
      ],
      "properties": {
        "is_proxy": {
          "type": "boolean"
        },
        "data_source_type": {
          "type": "string",
          "enum": [
            "mock",
            "public_proxy",
            "enterprise_internal",
            "mixed"
          ]
        },
        "data_sources": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/dataSource"
          }
        },
        "geographic_scope": {
          "type": "string"
        },
        "analysis_period": {
          "type": "string"
        },
        "target_company_context": {
          "type": "string"
        },
        "disclaimer": {
          "type": "string",
          "minLength": 20
        }
      }
    },
    "dataSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "source_name",
        "source_type",
        "role_in_engine"
      ],
      "properties": {
        "source_id": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "source_name": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "source_type": {
          "type": "string",
          "enum": [
            "public_dataset",
            "market_report",
            "mock",
            "enterprise_internal",
            "manual_assumption",
            "generated"
          ]
        },
        "file_path": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "role_in_engine": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "inputDataSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_rows_ingested",
        "total_rows_processed",
        "date_range",
        "records_by_input",
        "unit_standardization"
      ],
      "properties": {
        "total_rows_ingested": {
          "$ref": "#/definitions/nonNegativeInteger"
        },
        "total_rows_processed": {
          "$ref": "#/definitions/nonNegativeInteger"
        },
        "total_volume_processed": {
          "$ref": "#/definitions/nonNegativeNumber"
        },
        "volume_unit": {
          "$ref": "#/definitions/unit"
        },
        "date_range": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "start",
            "end"
          ],
          "properties": {
            "start": {
              "type": "string"
            },
            "end": {
              "type": "string"
            }
          }
        },
        "records_by_input": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "dataset_name",
              "rows_ingested",
              "rows_processed"
            ],
            "properties": {
              "dataset_name": {
                "$ref": "#/definitions/nonEmptyString"
              },
              "rows_ingested": {
                "$ref": "#/definitions/nonNegativeInteger"
              },
              "rows_processed": {
                "$ref": "#/definitions/nonNegativeInteger"
              }
            }
          }
        },
        "unit_standardization": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "standard_unit",
            "conversion_notes"
          ],
          "properties": {
            "standard_unit": {
              "$ref": "#/definitions/unit"
            },
            "conversion_notes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "dataQualityReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "usable_rate",
        "quality_level",
        "missing_fields",
        "imputed_fields",
        "invalid_region_count",
        "duplicate_records_count",
        "warnings"
      ],
      "properties": {
        "usable_rate": {
          "$ref": "#/definitions/ratio"
        },
        "quality_level": {
          "type": "string",
          "enum": [
            "High",
            "Medium",
            "Low"
          ]
        },
        "missing_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "imputed_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_origin_count": {
          "$ref": "#/definitions/nonNegativeInteger"
        },
        "missing_destination_count": {
          "$ref": "#/definitions/nonNegativeInteger"
        },
        "missing_volume_count": {
          "$ref": "#/definitions/nonNegativeInteger"
        },
        "invalid_region_count": {
          "$ref": "#/definitions/nonNegativeInteger"
        },
        "duplicate_records_count": {
          "$ref": "#/definitions/nonNegativeInteger"
        },
        "geocode_success_rate": {
          "$ref": "#/definitions/ratio"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "masterData": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "regions",
        "product_families",
        "candidate_hubs"
      ],
      "properties": {
        "regions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/region"
          }
        },
        "product_families": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/productFamilyMaster"
          }
        },
        "candidate_hubs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/candidateHub"
          }
        }
      }
    },
    "region": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "region_id",
        "region_name",
        "country",
        "level",
        "lat",
        "lon"
      ],
      "properties": {
        "region_id": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "region_name": {
          "$ref": "#/definitions/regionName"
        },
        "country": {
          "type": "string",
          "enum": [
            "KR"
          ]
        },
        "level": {
          "type": "string",
          "enum": [
            "si_do",
            "si_gun_gu",
            "custom_zone"
          ]
        },
        "parent_region_id": {
          "type": "string"
        },
        "lat": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "lon": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        }
      }
    },
    "productFamilyMaster": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_family",
        "product_family_name",
        "description",
        "default_sla_radius_km"
      ],
      "properties": {
        "product_family": {
          "$ref": "#/definitions/productFamily"
        },
        "product_family_name": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "description": {
          "type": "string"
        },
        "default_sla_radius_km": {
          "$ref": "#/definitions/nonNegativeNumber"
        },
        "default_unit": {
          "$ref": "#/definitions/unit"
        }
      }
    },
    "candidateHub": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hub_id",
        "hub_name",
        "region_id",
        "region_name",
        "lat",
        "lon",
        "hub_type",
        "base_capacity",
        "capacity_unit",
        "fixed_cost_usd_per_year",
        "eligible_product_families"
      ],
      "properties": {
        "hub_id": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "hub_name": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "region_id": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "region_name": {
          "$ref": "#/definitions/regionName"
        },
        "lat": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "lon": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "hub_type": {
          "type": "string",
          "enum": [
            "metro",
            "regional",
            "launch",
            "secure",
            "service_node",
            "crossdock",
            "port",
            "overflow"
          ]
        },
        "area_m2": {
          "$ref": "#/definitions/nonNegativeNumber"
        },
        "base_capacity": {
          "$ref": "#/definitions/nonNegativeNumber"
        },
        "effective_capacity": {
          "$ref": "#/definitions/nonNegativeNumber"
        },
        "capacity_unit": {
          "$ref": "#/definitions/unit"
        },
        "fixed_cost_usd_per_year": {
          "$ref": "#/definitions/nonNegativeNumber"
        },
        "eligible_product_families": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/productFamily"
          }
        }
      }
    },
    "demand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "annual_demand_by_region",
        "monthly_demand_by_region_product",
        "top_od_lanes"
      ],
      "properties": {
        "total_annual_volume": {
          "$ref": "#/definitions/nonNegativeNumber"
        },
        "volume_unit": {
          "$ref": "#/definitions/unit"
        },
        "annual_demand_by_region": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/annualDemandRecord"
          }
        },
        "monthly_demand_by_region_product": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/monthlyDemandRecord"
          }
        },
        "top_od_lanes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/odLane"
          }
        }
      }
    },
    "annualDemandRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "region_id",
        "region_name",
        "volume",
        "unit",
        "share_pct"
      ],
      "properties": {
        "region_id": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "region_name": {
          "$ref": "#/definitions/regionName"
        },
        "volume": {
          "$ref": "#/definitions/nonNegativeNumber"
        },
        "unit": {
          "$ref": "#/definitions/unit"
        },
        "share_pct": {
          "$ref": "#/definitions/percentage"
        }
      }
    },
    "monthlyDemandRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "region_id",
        "region_name",
        "product_family",
        "month",
        "volume",
        "unit",
        "seasonal_index"
      ],
      "properties": {
        "region_id": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "region_name": {
          "$ref": "#/definitions/regionName"
        },
        "product_family": {
          "$ref": "#/definitions/productFamily"
        },
        "month": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}$"
        },
        "volume": {
          "$ref": "#/definitions/nonNegativeNumber"
        },
        "unit": {
          "$ref": "#/definitions/unit"
        },
        "seasonal_index": {
          "$ref": "#/definitions/nonNegativeNumber"
        }
      }
    },
    "odLane": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "origin_region",
        "destination_region",
        "volume",
        "unit"
      ],
      "properties": {
        "origin_region": {
          "$ref": "#/definitions/regionName"
        },
        "destination_region": {
          "$ref": "#/definitions/regionName"
        },
        "product_family": {
          "$ref": "#/definitions/productFamily"
        },
        "volume": {
          "$ref": "#/definitions/nonNegativeNumber"
        },
        "unit": {
          "$ref": "#/definitions/unit"
        },
        "share_pct": {
          "$ref": "#/definitions/percentage"
        }
      }
    },
    "productSegmentation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "confidence_level",
        "rules_applied",
        "distribution",
        "notes"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "rule_based",
            "sku_master",
            "ml_classifier",
            "none"
          ]
        },
        "confidence_level": {
          "type": "string",
          "enum": [
            "High",
            "Medium",
            "Low"
          ]
        },
        "rules_file": {
          "type": "string"
        },
        "rules_applied": {
          "$ref": "#/definitions/nonNegativeInteger"
        },
        "distribution": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/productDistributionRecord"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "productDistributionRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_family",
        "volume",
        "unit",
        "share_pct"
      ],
      "properties": {
        "product_family": {
          "$ref": "#/definitions/productFamily"
        },
        "volume": {
          "$ref": "#/definitions/nonNegativeNumber"
        },
        "unit": {
          "$ref": "#/definitions/unit"
        },
        "share_pct": {
          "$ref": "#/definitions/percentage"
        }
      }
    },
    "baselineNetwork": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "current_network_assumption",
        "current_hubs",
        "current_total_cost",
        "current_service_level_pct",
        "current_risk_score"
      ],
      "properties": {
        "current_network_assumption": {
          "type": "string"
        },
        "current_hubs": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/currentHub"
          }
        },
        "current_total_cost": {
          "$ref": "#/definitions/costSummary"
        },
        "current_service_level_pct": {
          "$ref": "#/definitions/percentage"
        },
        "current_risk_score": {
          "$ref": "#/definitions/ratio"
        }
      }
    },
    "currentHub": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hub_id",
        "hub_name",
        "region_name",
        "capacity",
        "assigned_volume",
        "utilization_pct",
        "status"
      ],
      "properties": {
        "hub_id": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "hub_name": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "region_name": {
          "$ref": "#/definitions/regionName"
        },
        "role": {
          "$ref": "#/definitions/hubRole"
        },
        "capacity": {
          "$ref": "#/definitions/nonNegativeNumber"
        },
        "assigned_volume": {
          "$ref": "#/definitions/nonNegativeNumber"
        },
        "unit": {
          "$ref": "#/definitions/unit"
        },
        "utilization_pct": {
          "$ref": "#/definitions/nonNegativeNumber"
        },
        "status": {
          "$ref": "#/definitions/hubStatus"
        }
      }
    },
    "costSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currency",
